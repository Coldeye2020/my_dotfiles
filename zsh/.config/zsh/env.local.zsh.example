export DEFAULT_USER="your_username"

export CONFLUENCE_URL="https://confluence.your-company.com"
export CONFLUENCE_TOKEN_PATH="$HOME/.config/confluence/token"

# Java
export JAVA8_HOME="/Library/Java/JavaVirtualMachines/jdk1.8.0_361.jdk/Contents/Home"
export JAVA17_HOME="/Library/Java/JavaVirtualMachines/temurin-17.jdk/Contents/Home"
export JAVA_HOME="$JAVA8_HOME"
export PATH="$JAVA_HOME/bin:$PATH"
export MAVEN_OPTS="-Xms256m -Xmx1024m -Dfile.encoding=UTF-8"

# Thrift
export THRIFT2_HOME="/opt/homebrew/Cellar/thrift@0.9/0.9.3.1"
export THRIFT3_HOME="/opt/homebrew/Cellar/thrift/0.22.0"
export PATH="$THRIFT2_HOME/bin:$PATH"

# Python project paths
export CODE_PATH="$HOME/Documents/code/project"
export PYTHON_CODE="${CODE_PATH}/python"
export JAVA_CODE="${CODE_PATH}/java"
export SCRIPT_PYTHON="${PYTHON_CODE}/script"
export PYTHONPATH="${SCRIPT_PYTHON}:${SCRIPT_PYTHON}/your_project/gen_py${PYTHONPATH:+:$PYTHONPATH}"

# Conda environment
conda activate your_env

# Misc tool paths
export PATH=$PATH:/path/to/your/tool/bin
export PATH=/Applications/IntelliJ\ IDEA.app/Contents/plugins/maven/lib/maven3/bin:$PATH

# OpenClaw
[[ -f "$HOME/.openclaw/completions/openclaw.zsh" ]] && source "$HOME/.openclaw/completions/openclaw.zsh"
